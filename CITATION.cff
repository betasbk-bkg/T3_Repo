title: "Contrarian rate-damping in latency-affected crowd-sourced continuous control: simulation and frame-level mechanism validation"
authors:
  - family-names: "Song"
    given-names: "BongKeun"
    orcid: "https://orcid.org/0009-0008-3120-8126"
    email: "bongkeun.song@fau.de"
